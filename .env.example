# TelecomLens configuration
# Copy this file to .env and edit as needed.

# Database — SQLite (default) or any SQLAlchemy URL
DATABASE_URL=sqlite:///./telecomlens.db
# DATABASE_URL=postgresql://user:password@localhost:5432/telecomlens

# Folder to scan for batch bill imports
BILLS_FOLDER=bills

# Windows: path to the Poppler bin folder containing pdftotext.exe
# Linux/macOS: leave blank — pdftotext is found via PATH
POPPLER_PATH=poppler

# CORS origins — use * for local single-machine use.
# For network/shared deployments, restrict to the server's IP or hostname.
# CORS_ORIGINS=http://192.168.1.50:8000
CORS_ORIGINS=*
